{
  "name": "mui-create-material-you-theme",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BobesCZ/mui-create-material-you-theme.git"
  },
  "homepage": "https://bobescz.github.io/mui-create-material-you-theme/storybook-static",
  "description": "Material You (Material Design 3) theme generator for MUI React apps",
  "keywords": [
    "mui",
    "material-ui",
    "material-you",
    "material-design-3",
    "md3",
    "mui-theme",
    "mui-theming",
    "mui-theme-generator",
    "react-theme",
    "react-material-you",
    "material-you-theme",
    "material-you-mui"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/mui-create-material-you-theme.umd.js",
  "module": "./dist/mui-create-material-you-theme.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mui-create-material-you-theme.es.js",
      "require": "./dist/mui-create-material-you-theme.umd.js"
    },
    "./themeAugmentation": {
      "types": "./dist/themeAugmentation.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "prepare": "npm run build",
    "build": "vite build && npm run build:copy-dts-sources && npm run build:theme-augmentation-types",
    "build:copy-dts-sources": "node -e \"const fs=require('fs');const path=require('path');const walk=(dir)=>fs.readdirSync(dir,{withFileTypes:true}).flatMap((entry)=>{const full=path.join(dir,entry.name);return entry.isDirectory()?walk(full):[full];});for(const file of walk('src')){if(!file.endsWith('.d.ts')) continue;const out=path.join('dist',path.relative('src',file));fs.mkdirSync(path.dirname(out),{recursive:true});fs.copyFileSync(file,out);}\"",
    "build:theme-augmentation-types": "tsc -p tsconfig.theme-augmentation.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.2.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/playpen-sans": "^5.2.9",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0"
  }
}
